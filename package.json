{
	"name": "@creatorarmy/demand-engine-plugin",
	"version": "1.0.3",
	"type": "module",
	"description": "Creator Army demand engine plugin for Claude Code — short-form video ads and organic content.",
	"license": "MIT",
	"main": "./dist/index.js",
	"files": [
		".claude-plugin",
		"dist",
		"openclaw.plugin.json",
		"skills"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check-types": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"@anthropic-ai/claude-code": ">=1.0.0",
		"openclaw": ">=2026.3.24-beta.2"
	},
	"peerDependenciesMeta": {
		"openclaw": {
			"optional": true
		},
		"@anthropic-ai/claude-code": {
			"optional": true
		}
	},
	"openclaw": {
		"extensions": [
			"./dist/index.js"
		],
		"compat": {
			"pluginApi": ">=2026.3.24-beta.2",
			"minGatewayVersion": "2026.3.24-beta.2"
		},
		"build": {
			"openclawVersion": "2026.5.7",
			"pluginSdkVersion": "2026.5.7"
		},
		"install": {
			"clawhubSpec": "clawhub:@creatorarmy/demand-engine-plugin",
			"defaultChoice": "clawhub",
			"minHostVersion": ">=2026.3.24-beta.2"
		}
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^5.9.3"
	}
}
